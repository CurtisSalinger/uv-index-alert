# OpenUV API key (free at https://www.openuv.io/)
OPENUV_API_KEY=your_api_key_here

# Your location coordinates
LATITUDE=37.7749
LONGITUDE=-122.4194

# Twilio credentials (https://www.twilio.com/)
TWILIO_ACCOUNT_SID=your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
TWILIO_FROM_NUMBER=+1234567890

# Your phone number to receive alerts
TO_NUMBER=+1234567890

# UV index threshold (default: 3)
UV_THRESHOLD=3
